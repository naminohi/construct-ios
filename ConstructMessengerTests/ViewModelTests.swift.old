import XCTest
import CoreData
import Combine
@testable import ConstructMessenger

final class ViewModelTests: XCTestCase {

    var context: NSManagedObjectContext!
    var cancellables: Set<AnyCancellable>!

    override func setUp() {
        super.setUp()
        cancellables = Set<AnyCancellable>()

        // Create in-memory Core Data stack for testing
        let container = NSPersistentContainer(name: "ConstructMessenger")
        let description = NSPersistentStoreDescription()
        description.type = NSInMemoryStoreType
        container.persistentStoreDescriptions = [description]

        container.loadPersistentStores { description, error in
            if let error = error {
                fatalError("Failed to load in-memory store: \(error)")
            }
        }

        context = container.viewContext
    }

    override func tearDown() {
        context = nil
        cancellables = nil
        super.tearDown()
    }

    // MARK: - ChatsViewModel Tests

    func testChatsViewModel_Initialization() {
        let viewModel = ChatsViewModel()
        viewModel.setContext(context)

        XCTAssertFalse(viewModel.isSearching, "Should not be searching initially")
        XCTAssertNil(viewModel.searchError, "Should have no search error initially")
        XCTAssertTrue(viewModel.searchResults.isEmpty, "Search results should be empty initially")
    }

    func testChatsViewModel_SearchUsers() {
        let viewModel = ChatsViewModel()
        viewModel.setContext(context)

        let expectation = XCTestExpectation(description: "Search state updated")

        // Subscribe to isSearching changes
        viewModel.$isSearching
            .dropFirst() // Skip initial value
            .sink { isSearching in
                if isSearching {
                    expectation.fulfill()
                }
            }
            .store(in: &cancellables)

        // Trigger search
        viewModel.searchUsers(query: "alice")

        wait(for: [expectation], timeout: 1.0)
    }

    func testChatsViewModel_StartChat() {
        let viewModel = ChatsViewModel()
        viewModel.setContext(context)

        let user = PublicUserInfo(id: UUID().uuidString, username: "testuser")
        let chat = viewModel.startChat(with: user)

        XCTAssertNotNil(chat, "Chat should be created")
        XCTAssertEqual(chat?.otherUser?.username, "testuser", "Chat should be associated with correct user")
        XCTAssertEqual(chat?.otherUser?.displayName, "testuser", "DisplayName should be set")
    }

    func testChatsViewModel_StartChat_Duplicate() {
        let viewModel = ChatsViewModel()
        viewModel.setContext(context)

        let user = PublicUserInfo(id: UUID().uuidString, username: "testuser")

        // Create chat first time
        let chat1 = viewModel.startChat(with: user)
        XCTAssertNotNil(chat1)

        // Try to create again - should return existing
        let chat2 = viewModel.startChat(with: user)
        XCTAssertNotNil(chat2)
        XCTAssertEqual(chat1?.id, chat2?.id, "Should return same chat for same user")
    }

    func testChatsViewModel_DeleteChat() {
        let viewModel = ChatsViewModel()
        viewModel.setContext(context)

        // Create a chat
        let user = PublicUserInfo(id: UUID().uuidString, username: "testuser")
        guard let chat = viewModel.startChat(with: user) else {
            XCTFail("Failed to create chat")
            return
        }

        // Verify it exists
        let fetchRequest: NSFetchRequest<Chat> = Chat.fetchRequest()
        let countBefore = (try? context.fetch(fetchRequest).count) ?? 0
        XCTAssertGreaterThan(countBefore, 0, "Chat should exist before deletion")

        // Delete it
        viewModel.deleteChat(chat: chat)

        // Verify it's deleted
        let countAfter = (try? context.fetch(fetchRequest).count) ?? 0
        XCTAssertEqual(countAfter, countBefore - 1, "Chat should be deleted")
    }

    // MARK: - ChatViewModel Tests

    func testChatViewModel_Initialization() {
        // Create a chat
        let chat = Chat(context: context)
        chat.id = UUID().uuidString

        let user = User(context: context)
        user.id = UUID().uuidString
        user.username = "testuser"
        user.displayName = "testuser"
        chat.otherUser = user

        try? context.save()

        // Create ViewModel
        let viewModel = ChatViewModel(chat: chat, context: context)

        XCTAssertFalse(viewModel.isSending, "Should not be sending initially")
        XCTAssertNil(viewModel.errorMessage, "Should have no error initially")
        XCTAssertTrue(viewModel.messages.isEmpty, "Messages should be empty initially")
    }

    func testChatViewModel_SendMessage_NoSession() {
        let chat = Chat(context: context)
        chat.id = UUID().uuidString

        let user = User(context: context)
        user.id = UUID().uuidString
        user.username = "testuser"
        user.displayName = "testuser"
        chat.otherUser = user

        try? context.save()

        let viewModel = ChatViewModel(chat: chat, context: context)

        // Mock session manager with no current user
        SessionManager.shared.currentUserId = nil

        viewModel.sendMessage(text: "Test message")

        // Should not crash (gracefully handled)
        XCTAssertNotNil(viewModel) // Dummy assertion to verify no crash
    }

    func testChatViewModel_LoadMessages() {
        let chat = Chat(context: context)
        chat.id = UUID().uuidString

        let user = User(context: context)
        user.id = UUID().uuidString
        user.username = "testuser"
        user.displayName = "testuser"
        chat.otherUser = user

        // Create test messages
        for i in 0..<5 {
            let message = Message(context: context)
            message.id = UUID().uuidString
            message.fromUserId = user.id
            message.toUserId = "current-user"
            message.decryptedContent = "Test message \(i)"
            message.timestamp = Date().addingTimeInterval(Double(i))
            message.isSentByMe = false
            message.deliveryStatus = .delivered
            message.chat = chat
        }

        try? context.save()

        // Create ViewModel and verify messages loaded
        let viewModel = ChatViewModel(chat: chat, context: context)

        // Give time for async loading
        let expectation = XCTestExpectation(description: "Messages loaded")
        DispatchQueue.main.asyncAfter(deadline: .now() + 0.5) {
            XCTAssertEqual(viewModel.messages.count, 5, "Should load 5 messages")
            expectation.fulfill()
        }

        wait(for: [expectation], timeout: 1.0)
    }

    // MARK: - AuthViewModel Tests

    func testAuthViewModel_Initialization() {
        let viewModel = AuthViewModel()

        XCTAssertFalse(viewModel.isLoading, "Should not be loading initially")
        XCTAssertNil(viewModel.errorMessage, "Should have no error initially")
        XCTAssertFalse(viewModel.isAuthenticated, "Should not be authenticated initially")
    }

    func testAuthViewModel_ValidateRegistration_WeakPassword() {
        let viewModel = AuthViewModel()

        viewModel.register(username: "testuser", password: "weak")

        XCTAssertNotNil(viewModel.errorMessage, "Should have error for weak password")
    }

    func testAuthViewModel_ValidateRegistration_ShortUsername() {
        let viewModel = AuthViewModel()

        viewModel.register(username: "ab", password: "StrongPassword123")

        XCTAssertNotNil(viewModel.errorMessage, "Should have error for short username")
    }

    // MARK: - Performance Tests

    func testChatViewModel_LoadManyMessages_Performance() {
        let chat = Chat(context: context)
        chat.id = UUID().uuidString

        let user = User(context: context)
        user.id = UUID().uuidString
        user.username = "testuser"
        user.displayName = "testuser"
        chat.otherUser = user

        // Create 100 messages
        for i in 0..<100 {
            let message = Message(context: context)
            message.id = UUID().uuidString
            message.fromUserId = user.id
            message.toUserId = "current-user"
            message.decryptedContent = "Test message \(i)"
            message.timestamp = Date().addingTimeInterval(Double(i))
            message.isSentByMe = i % 2 == 0
            message.deliveryStatus = .delivered
            message.chat = chat
        }

        try? context.save()

        // Measure loading performance
        measure {
            let viewModel = ChatViewModel(chat: chat, context: context)
            // Wait for messages to load
            let expectation = XCTestExpectation(description: "Messages loaded")
            DispatchQueue.main.asyncAfter(deadline: .now() + 0.1) {
                expectation.fulfill()
            }
            wait(for: [expectation], timeout: 1.0)
        }
    }
}
