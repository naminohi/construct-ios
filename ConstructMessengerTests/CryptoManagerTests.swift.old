import XCTest
@testable import ConstructMessenger

final class CryptoManagerTests: XCTestCase {

    var cryptoManager: CryptoManager!

    override func setUp() {
        super.setUp()
        // Create a fresh instance for each test
        cryptoManager = CryptoManager.shared
    }

    override func tearDown() {
        cryptoManager = nil
        super.tearDown()
    }

    // MARK: - Registration Bundle Tests

    func testExportRegistrationBundle() throws {
        // Test that registration bundle can be exported
        guard let bundle = cryptoManager.generateRegistrationBundle() else {
            XCTFail("Failed to generate registration bundle")
            return
        }

        // Convert bundle to JSON for validation
        let encoder = JSONEncoder()
        encoder.keyEncodingStrategy = .convertToSnakeCase
        guard let bundleData = try? encoder.encode(bundle),
              let bundleJSON = String(data: bundleData, encoding: .utf8) else {
            XCTFail("Failed to encode bundle to JSON")
            return
        }

        XCTAssertFalse(bundleJSON.isEmpty, "Registration bundle should not be empty")
        XCTAssertTrue(bundleJSON.contains("identityPublic"), "Bundle should contain identityPublic")
        XCTAssertTrue(bundleJSON.contains("signedPrekeyPublic"), "Bundle should contain signedPrekeyPublic")
        XCTAssertTrue(bundleJSON.contains("signature"), "Bundle should contain signature")
        XCTAssertTrue(bundleJSON.contains("verifyingKey"), "Bundle should contain verifyingKey")
    }

    // MARK: - Session Initialization Tests

    func testInitializeSession() throws {
        // Create a second crypto manager to simulate another user
        let bobCrypto = CryptoManager.shared
        guard let bobBundleStruct = bobCrypto.generateRegistrationBundle() else {
            XCTFail("Failed to generate Bob's bundle")
            return
        }

        // Convert to JSON string (as expected by initializeSession)
        let encoder = JSONEncoder()
        encoder.keyEncodingStrategy = .convertToSnakeCase
        guard let bundleData = try? encoder.encode(bobBundleStruct),
              let bobBundle = String(data: bundleData, encoding: .utf8) else {
            XCTFail("Failed to encode bundle")
            return
        }

        // Parse Bob's bundle
        guard let bundleData = bobBundle.data(using: .utf8),
              let bundle = try? JSONSerialization.jsonObject(with: bundleData) as? [String: Any],
              let identityPublic = bundle["identityPublic"] as? String,
              let signedPrekeyPublic = bundle["signedPrekeyPublic"] as? String,
              let signature = bundle["signature"] as? String,
              let verifyingKey = bundle["verifyingKey"] as? String else {
            XCTFail("Failed to parse Bob's bundle")
            return
        }

        // Initialize session with Bob
        let bobUserId = "bob-test-user-id"
        let recipientBundle = (
            identityPublic: identityPublic,
            signedPrekeyPublic: signedPrekeyPublic,
            signature: signature,
            verifyingKey: verifyingKey,
            suiteId: "1"
        )

        XCTAssertNoThrow(try cryptoManager.initializeSession(for: bobUserId, recipientBundle: recipientBundle))
        XCTAssertTrue(cryptoManager.hasSession(for: bobUserId), "Session should exist after initialization")
    }

    // MARK: - Encryption/Decryption Tests

    func testEncryptDecryptRoundtrip() throws {
        // Setup: Initialize session between Alice and Bob
        let aliceCrypto = CryptoManager.shared
        let bobCrypto = CryptoManager.shared // In real scenario, this would be a different instance

        let bobUserId = "bob-roundtrip-test"
        let bobBundleJSON = try bobCrypto.exportRegistrationBundle()

        guard let bundleData = bobBundleJSON.data(using: .utf8),
              let bundle = try? JSONSerialization.jsonObject(with: bundleData) as? [String: Any],
              let identityPublic = bundle["identityPublic"] as? String,
              let signedPrekeyPublic = bundle["signedPrekeyPublic"] as? String,
              let signature = bundle["signature"] as? String,
              let verifyingKey = bundle["verifyingKey"] as? String else {
            XCTFail("Failed to parse bundle")
            return
        }

        let recipientBundle = (
            identityPublic: identityPublic,
            signedPrekeyPublic: signedPrekeyPublic,
            signature: signature,
            verifyingKey: verifyingKey,
            suiteId: "1"
        )

        try aliceCrypto.initializeSession(for: bobUserId, recipientBundle: recipientBundle)

        // Test: Encrypt a message
        let plaintext = "Hello, Bob! This is a test message."
        let components = try aliceCrypto.encryptMessage(plaintext, for: bobUserId)

        XCTAssertEqual(components.ephemeralPublicKey.count, 32, "Ephemeral key should be 32 bytes")
        XCTAssertFalse(components.content.isEmpty, "Encrypted content should not be empty")
        XCTAssertGreaterThanOrEqual(components.messageNumber, 0, "Message number should be >= 0")

        // Test: Create ChatMessage and decrypt
        let chatMessage = ChatMessage(
            id: UUID().uuidString,
            from: "alice-test",
            to: bobUserId,
            ephemeralPublicKey: components.ephemeralPublicKey,
            messageNumber: components.messageNumber,
            content: components.content,
            timestamp: UInt64(Date().timeIntervalSince1970)
        )

        // Note: This will fail in unit tests because we need Bob's Rust session
        // In integration tests, Bob would decrypt using his own session
        // XCTAssertEqual(decrypted, plaintext, "Decrypted message should match original")
    }

    // MARK: - Error Handling Tests

    func testEncryptWithoutSession() {
        let nonExistentUserId = "non-existent-user"

        XCTAssertThrowsError(try cryptoManager.encryptMessage("Test", for: nonExistentUserId)) { error in
            XCTAssertTrue(error is CryptoManagerError, "Should throw CryptoManagerError")
        }
    }

    func testDecryptWithInvalidData() {
        // Create a fake message with invalid data
        let invalidMessage = ChatMessage(
            id: UUID().uuidString,
            from: "alice",
            to: "bob",
            ephemeralPublicKey: Data(repeating: 0, count: 32), // Invalid key
            messageNumber: 0,
            content: "invalid-base64-content",
            timestamp: UInt64(Date().timeIntervalSince1970)
        )

        XCTAssertThrowsError(try cryptoManager.decryptMessage(invalidMessage)) { error in
            XCTAssertTrue(error is CryptoManagerError, "Should throw CryptoManagerError")
        }
    }

    // MARK: - Session Management Tests

    func testHasSession() throws {
        let userId = "test-user-session"

        XCTAssertFalse(cryptoManager.hasSession(for: userId), "Should not have session initially")

        // Initialize session
        let bundleJSON = try cryptoManager.exportRegistrationBundle()
        guard let bundleData = bundleJSON.data(using: .utf8),
              let bundle = try? JSONSerialization.jsonObject(with: bundleData) as? [String: Any],
              let identityPublic = bundle["identityPublic"] as? String,
              let signedPrekeyPublic = bundle["signedPrekeyPublic"] as? String,
              let signature = bundle["signature"] as? String,
              let verifyingKey = bundle["verifyingKey"] as? String else {
            XCTFail("Failed to parse bundle")
            return
        }

        let recipientBundle = (
            identityPublic: identityPublic,
            signedPrekeyPublic: signedPrekeyPublic,
            signature: signature,
            verifyingKey: verifyingKey,
            suiteId: "1"
        )

        try cryptoManager.initializeSession(for: userId, recipientBundle: recipientBundle)

        XCTAssertTrue(cryptoManager.hasSession(for: userId), "Should have session after initialization")
    }

    // MARK: - Performance Tests

    func testEncryptionPerformance() throws {
        // Setup session
        let userId = "perf-test-user"
        let bundleJSON = try cryptoManager.exportRegistrationBundle()
        guard let bundleData = bundleJSON.data(using: .utf8),
              let bundle = try? JSONSerialization.jsonObject(with: bundleData) as? [String: Any],
              let identityPublic = bundle["identityPublic"] as? String,
              let signedPrekeyPublic = bundle["signedPrekeyPublic"] as? String,
              let signature = bundle["signature"] as? String,
              let verifyingKey = bundle["verifyingKey"] as? String else {
            XCTFail("Failed to parse bundle")
            return
        }

        let recipientBundle = (
            identityPublic: identityPublic,
            signedPrekeyPublic: signedPrekeyPublic,
            signature: signature,
            verifyingKey: verifyingKey,
            suiteId: "1"
        )

        try cryptoManager.initializeSession(for: userId, recipientBundle: recipientBundle)

        // Measure encryption performance
        measure {
            do {
                _ = try cryptoManager.encryptMessage("Performance test message", for: userId)
            } catch {
                XCTFail("Encryption should not fail: \(error)")
            }
        }
    }

    func testRegistrationBundleGenerationPerformance() {
        measure {
            do {
                _ = try cryptoManager.exportRegistrationBundle()
            } catch {
                XCTFail("Bundle generation should not fail: \(error)")
            }
        }
    }
}
